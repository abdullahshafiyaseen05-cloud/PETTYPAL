import time\
from typing import Dict, List, Tuple\
\
import cv2\
import numpy as np\
import streamlit as st\
from ultralytics import YOLO\
\
st.set_page_config(page_title="AI Petty Shop Billing", page_icon="\uc0\u55357 \u57042 ", layout="wide")\
\
ITEM_PRICES = \{\
    "banana": 5,\
    "apple": 6,\
    "tomato": 7,\
    "potato": 8,\
    "cucumber": 9,\
    "carrot": 10,\
\}\
\
YOLO_ITEMS = \{"banana", "apple", "carrot"\}\
ALL_ITEMS = set(ITEM_PRICES.keys())\
CONFIDENCE_THRESHOLD = 0.45\
COOLDOWN_SECONDS = 1.6\
FRAME_WIDTH = 640\
FRAME_HEIGHT = 480\
\
_CAMERA = None\
\
\
def init_state() -> None:\
    defaults = \{\
        "camera_running": False,\
        "bill": \{item: 0 for item in ITEM_PRICES\},\
        "last_added_times": \{\},\
        "feedback_message": "",\
        "feedback_time": 0.0,\
        "last_detected_items": [],\
        "camera_error": "",\
    \}\
    for key, value in defaults.items():\
        if key not in st.session_state:\
            st.session_state[key] = value\
\
\
@st.cache_resource(show_spinner=True)\
def load_model():\
    return YOLO("yolov8n.pt")\
\
\
def get_camera():\
    global _CAMERA\
    if _CAMERA is None or not _CAMERA.isOpened():\
        _CAMERA = cv2.VideoCapture(0)\
        _CAMERA.set(cv2.CAP_PROP_FRAME_WIDTH, FRAME_WIDTH)\
        _CAMERA.set(cv2.CAP_PROP_FRAME_HEIGHT, FRAME_HEIGHT)\
        _CAMERA.set(cv2.CAP_PROP_BUFFERSIZE, 1)\
    return _CAMERA\
\
\
def release_camera():\
    global _CAMERA\
    if _CAMERA is not None:\
        try:\
            _CAMERA.release()\
        except Exception:\
            pass\
    _CAMERA = None\
\
\
atexit.register(release_camera)\
