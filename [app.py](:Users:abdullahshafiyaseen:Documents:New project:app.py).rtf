\
def clamp_box(x1, y1, x2, y2, w, h):\
    x1 = max(0, min(int(x1), w - 1))\
    y1 = max(0, min(int(y1), h - 1))\
    x2 = max(0, min(int(x2), w - 1))\
    y2 = max(0, min(int(y2), h - 1))\
    return x1, y1, x2, y2\
\
\
def contour_box_score(contour):\
    area = cv2.contourArea(contour)\
    if area <= 0:\
        return 0, 0, 0, 0, 0, 0\
    x, y, w, h = cv2.boundingRect(contour)\
    perimeter = cv2.arcLength(contour, True)\
    circularity = 0\
    if perimeter > 0:\
        circularity = (4 * np.pi * area) / (perimeter * perimeter)\
    aspect = max(w, h) / max(1, min(w, h))\
    return area, x, y, w, h, circularity, aspect\
\
\
def find_best_contour(mask, min_area=2000):\
    contours, _ = cv2.findContours(mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\
    best = None\
    best_area = 0\
    for contour in contours:\
        area = cv2.contourArea(contour)\
        if area >= min_area and area > best_area:\
            best = contour\
            best_area = area\
    return best\
\
\
def detect_color_items(frame: np.ndarray) -> List[Tuple[str, float, Tuple[int, int, int, int]]]:\
    detections = []\
    h, w = frame.shape[:2]\
    hsv = cv2.cvtColor(frame, cv2.COLOR_BGR2HSV)\
\
    kernel = np.ones((5, 5), np.uint8)\
\
    red1 = cv2.inRange(hsv, np.array([0, 90, 60]), np.array([10, 255, 255]))\
    red2 = cv2.inRange(hsv, np.array([160, 90, 60]), np.array([179, 255, 255]))\
    tomato_mask = cv2.bitwise_or(red1, red2)\
    tomato_mask = cv2.morphologyEx(tomato_mask, cv2.MORPH_OPEN, kernel)\
    tomato_mask = cv2.morphologyEx(tomato_mask, cv2.MORPH_CLOSE, kernel)\
    contour = find_best_contour(tomato_mask, min_area=2500)\
    if contour is not None:\
        area, x, y, bw, bh, circularity, aspect = contour_box_score(contour)\
        fill_ratio = area / max(1, bw * bh)\
        if circularity > 0.55 and aspect < 1.35 and fill_ratio > 0.5:\
            x1, y1, x2, y2 = clamp_box(x, y, x + bw, y + bh, w, h)\
            conf = min(0.88, 0.5 + min(area / (w * h), 0.25))\
            detections.append(("tomato", float(conf), (x1, y1, x2, y2)))\
\
    green_mask = cv2.inRange(hsv, np.array([35, 50, 40]), np.array([95, 255, 255]))\
    green_mask = cv2.morphologyEx(green_mask, cv2.MORPH_OPEN, kernel)\
    green_mask = cv2.morphologyEx(green_mask, cv2.MORPH_CLOSE, kernel)\
    contour = find_best_contour(green_mask, min_area=3500)\
    if contour is not None:\
        area, x, y, bw, bh, circularity, aspect = contour_box_score(contour)\
        elongated = aspect > 1.8\
        fill_ratio = area / max(1, bw * bh)\
        if elongated and fill_ratio > 0.35:\
            x1, y1, x2, y2 = clamp_box(x, y, x + bw, y + bh, w, h)\
            conf = min(0.82, 0.48 + min(area / (w * h), 0.2))\
            detections.append(("cucumber", float(conf), (x1, y1, x2, y2)))\
\
    potato_mask = cv2.inRange(hsv, np.array([8, 40, 35]), np.array([28, 255, 200]))\
    potato_mask = cv2.morphologyEx(potato_mask, cv2.MORPH_OPEN, kernel)\
    potato_mask = cv2.morphologyEx(potato_mask, cv2.MORPH_CLOSE, kernel)\
    contour = find_best_contour(potato_mask, min_area=2500)\
    if contour is not None:\
        area, x, y, bw, bh, circularity, aspect = contour_box_score(contour)\
        fill_ratio = area / max(1, bw * bh)\
        if 0.35 <= circularity <= 0.95 and aspect < 1.8 and fill_ratio > 0.45:\
            x1, y1, x2, y2 = clamp_box(x, y, x + bw, y + bh, w, h)\
            conf = min(0.78, 0.46 + min(area / (w * h), 0.18))\
            detections.append(("potato", float(conf), (x1, y1, x2, y2)))\
\
    return detections\
\
\
def detect_items(frame: np.ndarray, model) -> Tuple[np.ndarray, List[Tuple[str, float, Tuple[int, int, int, int]]]]:\
    resized = cv2.resize(frame, (FRAME_WIDTH, FRAME_HEIGHT))\
    annotated = resized.copy()\
    detections: List[Tuple[str, float, Tuple[int, int, int, int]]] = []\
\
    try:\
        results = model.predict(source=resized, conf=CONFIDENCE_THRESHOLD, verbose=False)\
        if results:\
            result = results[0]\
            for box in result.boxes:\
                cls_id = int(box.cls[0].item())\
                label = model.names.get(cls_id, str(cls_id))\
                conf = float(box.conf[0].item())\
                if label in YOLO_ITEMS and conf >= CONFIDENCE_THRESHOLD:\
                    x1, y1, x2, y2 = map(int, box.xyxy[0].tolist())\
                    x1, y1, x2, y2 = clamp_box(x1, y1, x2, y2, FRAME_WIDTH, FRAME_HEIGHT)\
                    detections.append((label, conf, (x1, y1, x2, y2)))\
    except Exception:\
        pass\
\
    detections.extend(detect_color_items(resized))\
\
    deduped = \{\}\
    for item, conf, box in detections:\
        if item not in ALL_ITEMS:\
            continue\
        if item not in deduped or conf > deduped[item][0]:\
            deduped[item] = (conf, box)\
\
    final_detections = [(item, values[0], values[1]) for item, values in deduped.items()]\
\
    for item, conf, (x1, y1, x2, y2) in final_detections:\
        color = (32, 181, 74)\
        cv2.rectangle(annotated, (x1, y1), (x2, y2), color, 2)\
        label = f"\{item\} \{conf:.2f\}"\
        cv2.rectangle(annotated, (x1, max(0, y1 - 28)), (x1 + max(140, len(label) * 8), y1), color, -1)\
        cv2.putText(\
            annotated,\
            label,\
            (x1 + 6, y1 - 8),\
            cv2.FONT_HERSHEY_SIMPLEX,\
            0.55,\
            (255, 255, 255),\
            2,\
            cv2.LINE_AA,\
        )\
\
    if not final_detections:\
        cv2.putText(\
            annotated,\
            "No supported item detected",\
            (20, 35),\
            cv2.FONT_HERSHEY_SIMPLEX,\
            0.8,\
            (255, 255, 255),\
            2,\
            cv2.LINE_AA,\
        )\
\
    return annotated, final_detections\
\
\
def add_items_to_bill(detections: List[Tuple[str, float, Tuple[int, int, int, int]]]) -> None:\
    now = time.time()\
    added = []\
    for item in sorted(\{item for item, _, _ in detections\}):\
        last_time = st.session_state["last_added_times"].get(item, 0.0)\
        if now - last_time >= COOLDOWN_SECONDS:\
            st.session_state["bill"][item] += 1\
            st.session_state["last_added_times"][item] = now\
            added.append(item)\
\
    if added:\
        st.session_state["feedback_message"] = "\uc0\u9989  Item Added: " + ", ".join(added)\
        st.session_state["feedback_time"] = now\
\
\
def render_bill():\
    bill = st.session_state["bill"]\
    rows = []\
    grand_total = 0\
\
    for item, qty in bill.items():\
        if qty > 0:\
            price = ITEM_PRICES[item]\
            total = qty * price\
            grand_total += total\
            rows.append(\
                f"""\
                <tr>\
                    <td style="padding:10px 8px;border-bottom:1px solid #e9ecef;text-transform:capitalize;">\{item\}</td>\
                    <td style="padding:10px 8px;border-bottom:1px solid #e9ecef;text-align:center;">\{qty\}</td>\
                    <td style="padding:10px 8px;border-bottom:1px solid #e9ecef;text-align:right;">\uc0\u8377 \{price\}</td>\
                    <td style="padding:10px 8px;border-bottom:1px solid #e9ecef;text-align:right;font-weight:600;">\uc0\u8377 \{total\}</td>\
                </tr>\
                """\
            )\
\
    if rows:\
        table_html = f"""\
        <div style="background:#ffffff;border:1px solid #e6e6e6;border-radius:16px;padding:14px;box-shadow:0 6px 18px rgba(0,0,0,0.06);">\
            <table style="width:100%;border-collapse:collapse;font-size:15px;">\
                <thead>\
                    <tr style="background:#f8f9fa;">\
                        <th style="text-align:left;padding:10px 8px;border-bottom:1px solid #dee2e6;">Item</th>\
                        <th style="text-align:center;padding:10px 8px;border-bottom:1px solid #dee2e6;">Qty</th>\
                        <th style="text-align:right;padding:10px 8px;border-bottom:1px solid #dee2e6;">Price</th>\
                        <th style="text-align:right;padding:10px 8px;border-bottom:1px solid #dee2e6;">Total</th>\
                    </tr>\
                </thead>\
                <tbody>\
                    \{''.join(rows)\}\
                </tbody>\
            </table>\
        </div>\
        """\
        st.markdown(table_html, unsafe_allow_html=True)\
    else:\
        st.info("\uc0\u55357 \u57042  Bill is empty. Start the camera and show an item.")\
\
    st.markdown(\
        f"""\
        <div style="margin-top:14px;background:linear-gradient(135deg,#fff8e1,#ffe0b2);border:1px solid #ffd180;border-radius:16px;padding:18px;">\
            <div style="font-size:18px;font-weight:700;">\uc0\u55357 \u56496  Overall Total</div>\
            <div style="font-size:34px;font-weight:800;margin-top:6px;">\uc0\u8377 \{grand_total\}</div>\
        </div>\
        """,\
        unsafe_allow_html=True,\
    )\
\
    st.markdown("### Price List")\
    for item, price in ITEM_PRICES.items():\
        st.markdown(f"- \{item.capitalize()\}: \uc0\u8377 \{price\}")\
